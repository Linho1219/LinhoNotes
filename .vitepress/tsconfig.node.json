{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": ["config.mts", "node/**/*", "node/modules.d.ts"],
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true
  }
}
