{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["theme/**/*", "theme/**/*.vue", "theme/vite-env.d.ts"],
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "paths": {
      "@theme/*": ["./theme/*"],
      "@components/*": ["./theme/components/*"],
      "@features/*": ["./theme/features/*"]
    }
  }
}
