{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["theme/**/*.ts", "theme/**/*.vue", "shared/**/*.ts", "env.d.ts"],
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./*"], // temporary, for compatibility
      "@theme/*": ["./theme/*"],
      "@shared/*": ["./shared/*"]
    }
  }
}
